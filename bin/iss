#!/usr/bin/env bash
# iss — the git-issues CLI.
#
# Delegates to the Rust binary built in this workspace. Picks
# the most recently built of release/debug; builds release on
# demand if neither exists.

set -euo pipefail

here="$(cd "$(dirname "$0")" && pwd)"
workspace_root="$(cd "$here/.." && pwd)"

release_bin="$workspace_root/target/release/iss"
debug_bin="$workspace_root/target/debug/iss"

# Pick the newer of the two when both exist, so a fresh `cargo
# build` (debug, by default) doesn't get shadowed by a stale
# release binary from weeks ago.
if [[ -x "$release_bin" && -x "$debug_bin" ]]; then
    if [[ "$debug_bin" -nt "$release_bin" ]]; then
        exec "$debug_bin" "$@"
    else
        exec "$release_bin" "$@"
    fi
fi

if [[ -x "$release_bin" ]]; then
    exec "$release_bin" "$@"
fi

if [[ -x "$debug_bin" ]]; then
    exec "$debug_bin" "$@"
fi

echo "iss: no built binary at $release_bin or $debug_bin; building release..." >&2
cargo build --release --manifest-path "$workspace_root/Cargo.toml" -p iss >&2
exec "$release_bin" "$@"
