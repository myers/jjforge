# Per-experiment scratch directories. Test harnesses build bare git
# remotes and jj clones under these; they should never be tracked.
experiments/**/.scratch/
experiments/**/.scratch-followup/

# Per-crate scratch directories. Same role as above, but for
# `crates/<x>/tests/.scratch/` integration tests.
crates/**/tests/.scratch/

# Cargo build dirs in experiments.
experiments/**/target/

# Test-repo dirs inside experiments. The dir itself is tracked
# (for fixtures like a.txt), but local VCS state inside it is not.
experiments/**/test-repo/.jj/
experiments/**/test-repo/.git/

# Workspace-level Cargo build dir (root Cargo.toml lives here per
# crates/jjf-merge — see issue e2e473b).
/target/

blog/public/

# Read-only reference clones (e.g. ./reference/beads). Not part
# of jjforge; cloned in-tree for grep/cross-reference.
/reference/

# One-shot operational migration scripts that mutate planner
# state. Kept locally for re-run / audit; never committed.
experiments/drop-epic-labels/
