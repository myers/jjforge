# Per-experiment scratch directories. Test harnesses build bare git
# remotes and jj clones under these; they should never be tracked.
experiments/**/.scratch/
experiments/**/.scratch-followup/

# Per-crate scratch directories. Same role as above, but for
# `crates/<x>/tests/.scratch/` integration tests.
crates/**/tests/.scratch/

# Cargo build dirs in experiments.
experiments/**/target/

# Workspace-level Cargo build dir (root Cargo.toml lives here per
# crates/jjf-merge — see issue e2e473b).
/target/

blog/public/
